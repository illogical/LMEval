# Eval system backend port
PORT=3200

# LMApi connection
LMAPI_BASE_URL=http://localhost:3111

# Ollama keep-alive duration — how long a model stays loaded in VRAM after a request.
# Mirrors Ollama's own default (5m). Set to 0 to unload immediately, -1 to keep forever.
OLLAMA_KEEP_ALIVE=5m

# LMApi retry configuration
LMAPI_RETRY_COUNT=3
LMAPI_RETRY_DELAY_MS=2000

# Maximum parallel cell executions per evaluation run
EVAL_CONCURRENCY=8
